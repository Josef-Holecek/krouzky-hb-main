rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /clubs/{clubId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /trainers/{trainerId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}